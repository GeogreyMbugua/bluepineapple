{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],

    "allowJs": false,

    "noEmit": true,

    "incremental": true,

    "jsx": "react-jsx",

    "plugins": [
      {
        "name": "next"
      }
    ],

    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@blue-pineapple/iam": ["../../packages/iam/src/index.ts"],
      "@blue-pineapple/shared": ["../../packages/shared/src/index.ts"],
      "@blue-pineapple/shared/*": ["../../packages/shared/src/*"]
    }
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}