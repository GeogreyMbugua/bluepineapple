  isEmergency      Boolean          @default(false)
  isPrimary        Boolean          @default(false)
  metadata         Json?
  createdAt        DateTime         @default(now())

  customer    Customer @relation("CustomerReferrer", fields: [customerId], references: [id], onDelete: Cascade)
  related     Customer @relation("CustomerRelated", fields: [relatedCustomerId], references: [id], onDelete: Cascade)

  @@unique([customerId, relatedCustomerId, type])
  @@index([customerId])
  @@index([relatedCustomerId])
  @@index([type])
  @@map("customer_relationships")
}

model CustomerDocument {
  id                String         @id @default(uuid())
  customerId        String
  type              DocumentType
  documentNumber    String?
  issuingCountry    String?
  issuingAuthority  String?
  issueDate         DateTime?
  expiryDate        DateTime?
  status            DocumentStatus @default(PENDING)
  fileUrl           String?
  fileKey           String?
  mimeType          String?
  fileSize          Int?
  verifiedBy        String?
  verifiedAt        DateTime?
  notes             String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@index([status])
  @@index([expiryDate])
  @@map("customer_documents")
}

model LoyaltyTier {
  id              String       @id @default(uuid())
  name            String       @unique
  code            String       @unique
  level           Int          @default(0)
  minPoints       Int          @default(0)
  minSpend        Decimal?     @db.Decimal(12, 2)
  minBookings     Int?         @default(0)
  benefits        Json?
  color           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  accounts LoyaltyAccount[]

  @@index([level])
  @@index([isActive])
  @@map("loyalty_tiers")
}

model LoyaltyAccount {
  id                String    @id @default(uuid())
  customerId        String    @unique
  tierId            String
  pointsBalance     Int       @default(0)
  totalPointsEarned Int       @default(0)
  totalPointsRedeemed Int      @default(0)
  lifetimeEarnings  Decimal   @db.Decimal(12, 2) @default(0)
  currentValue      Decimal   @db.Decimal(12, 2) @default(0)
  enrolledAt        DateTime  @default(now())
  tierUpgradedAt    DateTime?
  tierExpiresAt     DateTime?
  metadata          Json?
  updatedAt         DateTime  @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier     LoyaltyTier @relation(fields: [tierId], references: [id])

  @@index([customerId])
  @@index([tierId])
  @@index([pointsBalance])
  @@map("loyalty_accounts")
}

//
// FINANCE DOMAIN
//

enum PaymentProviderType {
  MPESA
  STRIPE
  FLUTTERWAVE
  PESAPAL
  CASH
  BANK_TRANSFER
}

enum PaymentMethod {
  CARD
  MPESA
  BANK_TRANSFER
  CASH
  WALLET
  CORPORATE_CREDIT
  GIFT_CARD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum IntentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  EXPIRED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum WalletType {
  CUSTOMER
  PARTNER
  CORPORATE
  REWARD
  GIFT_CARD
  INVESTOR
  STORE_CREDIT
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  TRANSFER
  EXPIRATION
  ADJUSTMENT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

enum RefundType {
  FULL
  PARTIAL
  MANUAL
  AUTOMATIC
}

enum SettlementStatus {
  CREATED
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum SettlementType {
  PARTNER_PAYOUT
  SUPPLIER_PAYMENT
  OWNER_DISTRIBUTION
  COMMISSION
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum RevenueRecognitionStatus {
  PENDING
  RECOGNIZED
  DEFERRED
}

enum TaxCategory {
  VAT
  TOURISM_LEVY
  MARINE_CONSERVATION_FEE
  SERVICE_CHARGE
  COUNTY_TAX
  PROPERTY_TAX
  INCOME_TAX
}

enum ReconciliationStatus {
  PENDING
  IN_PROGRESS
  RECONCILED
  DISCREPANCY
  RESOLVED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

model PaymentProvider {
  id              String   @id @default(uuid())
  type            PaymentProviderType
  name            String
  isActive        Boolean  @default(true)
  config          Json?
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        Payment[]
  providerResponses PaymentProviderResponse[]

  @@index([type])
  @@index([isActive])
  @@map("payment_providers")
}

model PaymentIntent {
  id                String       @id @default(uuid())
  intentReference   String       @unique
  bookingId         String?
  commercialSummaryId String?
  customerId        String?
  partnerId         String?
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("KES")
  status            IntentStatus @default(PENDING)
  paymentMethod     PaymentMethod
  providerType      PaymentProviderType
  idempotencyKey    String?      @unique
  correlationId     String?
  metadata          Json?
  expiresAt         DateTime?
  capturedAt        DateTime?
  cancelledAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  retryCount        Int          @default(0)
  maxRetries        Int          @default(3)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payments          Payment[]
  providerResponses PaymentProviderResponse[]

  @@index([intentReference])
  @@index([bookingId])
  @@index([status])
  @@index([customerId])
  @@index([partnerId])
  @@index([correlationId])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@map("payment_intents")
}

model Payment {
  id                 String       @id @default(uuid())
  paymentReference   String       @unique
  intentId           String
  providerId         String?
  amount             Decimal      @db.Decimal(12, 2)
  currency           String       @default("KES")
  status             PaymentStatus
  paymentMethod      PaymentMethod
  providerType       PaymentProviderType
  providerPaymentId  String?
  authorizationCode  String?
  providerResponse   Json?
  failureCode        String?
  failureReason      String?
  metadata           Json?
  capturedAt         DateTime?
  settledAt          DateTime?
  refundedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  version            Int          @default(1)

  intent             PaymentIntent @relation(fields: [intentId], references: [id], onDelete: Restrict)
  provider           PaymentProvider? @relation(fields: [providerId], references: [id])

  refunds            Refund[]
  providerResponses  PaymentProviderResponse[]
  ledgerEntries      LedgerEntry[]

  @@index([paymentReference])
  @@index([intentId])
  @@index([status])
  @@index([providerId])
  @@index([createdAt])
  @@map("payments")
}

model PaymentProviderResponse {
  id                String   @id @default(uuid())
  paymentIntentId   String?
  paymentId         String?
  providerId        String?
  providerName      String
  providerPaymentId String?
  requestPayload    Json?
  responsePayload   Json?
  isSuccess         Boolean
  errorCode         String?
  errorMessage      String?
  httpStatusCode    Int?
  latencyMs         Int?
  createdAt         DateTime @default(now())

  paymentIntent     PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  payment           Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  provider          PaymentProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([paymentIntentId])
  @@index([paymentId])
  @@index([providerId])
  @@index([providerPaymentId])
  @@index([createdAt])
  @@map("payment_provider_responses")
}

model LedgerEntry {
  id              String           @id @default(uuid())
  entryReference  String           @unique
  entryType       LedgerEntryType
  accountCode     String
  accountName     String
  debitAmount     Decimal?         @db.Decimal(12, 2)
  creditAmount    Decimal?         @db.Decimal(12, 2)
  currency        String           @default("KES")
  exchangeRate    Decimal?         @db.Decimal(12, 6)
  baseCurrencyAmount Decimal?      @db.Decimal(12, 2)
  sourceDomain    String
  sourceEntityId  String
  sourceEntityType String
  description     String
  paymentId       String?
  invoiceId       String?
  walletId        String?
  settlementId    String?
  refundId        String?
  taxLedgerEntryId String?
  journalEntryId  String?
  metadata        Json?
  postedAt        DateTime
  createdBy       String?
  correlationId   String?
  fiscalPeriodId  String?
  version         Int              @default(1)
  createdAt       DateTime         @default(now())

  payment         Payment?      @relation(fields: [paymentId], references: [id])
  invoices        Invoice[]     @relation("LedgerInvoiceEntries")
  wallets         Wallet[]      @relation("LedgerWalletEntries")

  @@index([entryReference])
  @@index([entryType])
  @@index([accountCode])
  @@index([sourceDomain])
  @@index([sourceEntityId, sourceEntityType])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([walletId])
  @@index([settlementId])
  @@index([correlationId])
  @@index([fiscalPeriodId])
  @@index([postedAt])
  @@map("ledger_entries")
}

model Wallet {
  id                 String           @id @default(uuid())
  walletReference    String           @unique
  walletType         WalletType
  status             WalletStatus     @default(ACTIVE)
  ownerId            String
  ownerType          String
  currency           String           @default("KES")
  balance            Decimal          @db.Decimal(12, 2) @default(0)
  availableBalance   Decimal          @db.Decimal(12, 2) @default(0)
  frozenAmount       Decimal          @db.Decimal(12, 2) @default(0)
  expiresAt          DateTime?
  closedAt           DateTime?
  closedReason       String?
  metadata           Json?
  version            Int              @default(1)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  transactions       WalletTransaction[]
  ledgerEntries      LedgerEntry[]     @relation("LedgerWalletEntries")

  @@index([walletReference])
  @@index([walletType])
  @@index([status])
  @@index([ownerId, ownerType])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("wallets")
}

model WalletTransaction {
  id                String           @id @default(uuid())
  transactionReference String       @unique
  walletId          String
  transactionType   WalletTransactionType
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("KES")
  balanceBefore     Decimal          @db.Decimal(12, 2)
  balanceAfter      Decimal          @db.Decimal(12, 2)
  relatedWalletId   String?
  relatedPaymentId  String?
  relatedInvoiceId  String?
  relatedSettlementId String?
  relatedRefundId   String?
  description       String
  metadata          Json?
  createdBy         String?
  createdAt         DateTime         @default(now())

  wallet            Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([transactionReference])
  @@index([walletId])
  @@index([transactionType])
  @@index([relatedWalletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Invoice {
  id                String       @id @default(uuid())
  invoiceReference  String       @unique
  bookingId         String?
  quoteId           String?
  customerId        String?
  partnerId         String?
  commercialSummaryId String?
  status            InvoiceStatus @default(DRAFT)
  subtotal          Decimal      @db.Decimal(12, 2)
  taxTotal          Decimal      @db.Decimal(12, 2) @default(0)
  discountTotal     Decimal      @db.Decimal(12, 2) @default(0)
  grandTotal        Decimal      @db.Decimal(12, 2)
  currency          String       @default("KES")
  outstandingBalance Decimal     @db.Decimal(12, 2)
  issuedAt          DateTime?
  dueAt             DateTime?
  paidAt            DateTime?
  cancelledAt       DateTime?
  creditNoteApplied Decimal      @db.Decimal(12, 2) @default(0)
  notes             String?
  metadata          Json?
  version           Int          @default(1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  items             InvoiceItem[]
  ledgerEntries     LedgerEntry[] @relation("LedgerInvoiceEntries")

  @@index([invoiceReference])
  @@index([bookingId])
  @@index([quoteId])
  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([dueAt])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id              String    @id @default(uuid())
  invoiceId       String
  description     String
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(12, 2)
  totalPrice      Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  taxRate         Decimal?  @db.Decimal(5, 4)
  taxAmount       Decimal?  @db.Decimal(12, 2)
  discountAmount  Decimal?  @db.Decimal(12, 2)
  itemType        String
  referenceId     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([itemType])
  @@map("invoice_items")
}

model Refund {
  id                String       @id @default(uuid())
  refundReference   String       @unique
  paymentId         String
  invoiceId         String?
  customerId        String?
  partnerId         String?
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("KES")
  status            RefundStatus @default(PENDING)
  refundType        RefundType
  reason            String
  providerRefundId  String?
  providerResponse  Json?
  failureReason     String?
  approvedAt        DateTime?
  completedAt       DateTime?
  metadata          Json?
  version           Int          @default(1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payment           Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([refundReference])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("refunds")
}

model RefundRequest {
  id                String       @id @default(uuid())
  requestReference  String       @unique
  bookingId         String?
  paymentIntentId   String?
  paymentId         String?
  refundId          String?
  customerId        String?
  partnerId         String?
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("KES")
  status            String       @default("PENDING")
  reason            String
  requestedBy       String
  approvedBy        String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([requestReference])
  @@index([bookingId])
  @@index([paymentId])
  @@index([refundId])
  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("refund_requests")
}

model Settlement {
  id                String           @id @default(uuid())
  settlementReference String        @unique
  settlementType    SettlementType
  status            SettlementStatus @default(CREATED)
  totalAmount       Decimal          @db.Decimal(12, 2)
  currency          String           @default("KES")
  partnerId         String?
  recipientName     String?
  recipientAccount  String?
  bankName          String?
  approvedAt        DateTime?
  processedAt       DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  description       String?
  metadata          Json?
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime     @updatedAt

  items             SettlementItem[]

  @@index([settlementReference])
  @@index([settlementType])
  @@index([status])
  @@index([partnerId])
  @@index([createdAt])
  @@map("settlements")
}

model SettlementItem {
  id              String    @id @default(uuid())
  settlementId    String
  entityType      String
  entityId        String
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  feeAmount       Decimal   @db.Decimal(12, 2) @default(0)
  netAmount       Decimal   @db.Decimal(12, 2)
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  settlement      Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([entityType, entityId])
  @@map("settlement_items")
}

model Account {
  id              String       @id @default(uuid())
  accountCode     String       @unique
  accountName     String
  accountType     AccountType
  parentCode      String?
  isActive        Boolean      @default(true)
  isPosting       Boolean      @default(true)
  description     String?
  currency        String       @default("KES")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  journalEntries  JournalEntryItem[]

  @@index([accountCode])
  @@index([accountType])
  @@index([isActive])
  @@map("accounts")
}

model JournalEntry {
  id              String           @id @default(uuid())
  journalReference String          @unique
  status          JournalEntryStatus @default(DRAFT)
  entryDate       DateTime
  description     String
  totalDebit      Decimal          @db.Decimal(12, 2)
  totalCredit     Decimal          @db.Decimal(12, 2)
  fiscalPeriodId  String?
  isBalanced      Boolean          @default(false)
  postedAt        DateTime?
  reversedAt      DateTime?
  reversalReference String?
  metadata        Json?
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime     @updatedAt

  items           JournalEntryItem[]

  @@index([journalReference])
  @@index([status])
  @@index([entryDate])
  @@index([fiscalPeriodId])
  @@index([createdAt])
  @@map("journal_entries")
}

model JournalEntryItem {
  id              String    @id @default(uuid())
  journalEntryId  String
  accountId       String
  accountCode     String
  accountName     String
  entryType       LedgerEntryType
  debitAmount     Decimal?  @db.Decimal(12, 2)
  creditAmount    Decimal?  @db.Decimal(12, 2)
  currency        String    @default("KES")
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([accountCode])
  @@map("journal_entry_items")
}

model FiscalPeriod {
  id              String    @id @default(uuid())
  periodCode      String    @unique
  periodName      String
  startDate       DateTime
  endDate         DateTime
  isClosed        Boolean   @default(false)
  closedAt        DateTime?
  closedBy        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([periodCode])
  @@index([startDate, endDate])
  @@index([isClosed])
  @@map("fiscal_periods")
}

model RevenueRecognition {
  id                  String                   @id @default(uuid())
  recognitionReference String                  @unique
  invoiceId           String?
  paymentId           String?
  contractValue       Decimal                  @db.Decimal(12, 2)
  recognizedRevenue   Decimal                  @db.Decimal(12, 2) @default(0)
  deferredRevenue     Decimal                  @db.Decimal(12, 2)
  currency             String                   @default("KES")
  status               RevenueRecognitionStatus @default(PENDING)
  recognitionSchedule  Json?
  recognizedAt         DateTime?
  deferredAt           DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  events              RevenueRecognitionEvent[]

  @@index([recognitionReference])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
  @@map("revenue_recognitions")
}

model RevenueRecognitionEvent {
  id                    String    @id @default(uuid())
  revenueRecognitionId  String
  eventType             String
  recognizedAmount      Decimal   @db.Decimal(12, 2)
  currency              String    @default("KES")
  eventDate             DateTime
  description           String?
  metadata              Json?
  createdAt             DateTime  @default(now())

  revenueRecognition    RevenueRecognition @relation(fields: [revenueRecognitionId], references: [id], onDelete: Cascade)

  @@index([revenueRecognitionId])
  @@index([eventType])
  @@index([eventDate])
  @@map("revenue_recognition_events")
}

model TaxLedgerEntry {
  id              String    @id @default(uuid())
  taxCategory     TaxCategory
  taxRuleId       String?
  taxableAmount   Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  rate            Decimal   @db.Decimal(5, 4)
  isInclusive     Boolean   @default(false)
  jurisdiction    String
  sourceDomain    String
  sourceEntityId  String
  sourceEntityType String
  description     String
  ledgerEntryId   String?
  metadata        Json?
  postedAt        DateTime
  createdAt       DateTime  @default(now())

  @@index([taxCategory])
  @@index([taxRuleId])
  @@index([sourceDomain])
  @@index([sourceEntityId, sourceEntityType])
  @@index([postedAt])
  @@map("tax_ledger_entries")
}

model CommissionSettlement {
  id                    String    @id @default(uuid())
  commissionReference   String    @unique
  partnerId             String
  commissionRuleId      String?
  bookingId             String?
  baseAmount            Decimal   @db.Decimal(12, 2)
  commissionAmount      Decimal   @db.Decimal(12, 2)
  currency              String    @default("KES")
  rate                  Decimal   @db.Decimal(5, 4)
  status                String    @default("CALCULATED")
  settlementId          String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([commissionReference])
  @@index([partnerId])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
  @@map("commission_settlements")
}

model ReconciliationBatch {
  id                String           @id @default(uuid())
  batchReference    String           @unique
  batchType         String
  status            ReconciliationStatus @default(PENDING)
  providerStatement Json?
  ledgerStatement   Json?
  totalProviderAmount Decimal      @db.Decimal(12, 2)
  totalLedgerAmount Decimal        @db.Decimal(12, 2)
  varianceAmount    Decimal         @db.Decimal(12, 2) @default(0)
  varianceCount     Int             @default(0)
  reconciledAt      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  items             ReconciliationItem[]

  @@index([batchReference])
  @@index([batchType])
  @@index([status])
  @@index([createdAt])
  @@map("reconciliation_batches")
}

model ReconciliationItem {
  id                String    @id @default(uuid())
  batchId           String
  itemType          String
  providerReference String?
  ledgerReference   String?
  providerAmount    Decimal?  @db.Decimal(12, 2)
  ledgerAmount      Decimal?  @db.Decimal(12, 2)
  varianceAmount    Decimal?  @db.Decimal(12, 2)
  status            String    @default("MATCHED")
  resolutionNotes   String?
  resolvedAt        DateTime?
  resolvedBy        String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  batch             ReconciliationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
  @@index([itemType])
  @@map("reconciliation_items")
}

model Payout {
  id                String       @id @default(uuid())
  payoutReference   String       @unique
  payoutType        String
  status            PayoutStatus @default(PENDING)
  recipientId       String
  recipientType     String
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("KES")
  fee               Decimal      @db.Decimal(12, 2) @default(0)
  netAmount         Decimal      @db.Decimal(12, 2)
  settlementId      String?
  approvedAt        DateTime?
  processedAt       DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  metadata          Json?
  version           Int          @default(1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime  @updatedAt

  items             PayoutItem[]

  @@index([payoutReference])
  @@index([payoutType])
  @@index([status])
  @@index([recipientId, recipientType])
  @@index([settlementId])
  @@index([createdAt])
  @@map("payouts")
}

model PayoutItem {
  id              String    @id @default(uuid())
  payoutId        String
  entityType      String
  entityId        String
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  payout          Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([payoutId])
  @@index([entityType, entityId])
  @@map("payout_items")
}

//
// FINANCE AUDIT
//

enum FinanceAuditAction {
  PAYMENT_INTENT_CREATED
  PAYMENT_AUTHORIZED
  PAYMENT_CAPTURED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  PAYMENT_EXPIRED
  LEDGER_ENTRY_POSTED
  WALLET_CREDITED
  WALLET_DEBITED
  WALLET_FROZEN
  WALLET_CLOSED
  INVOICE_ISSUED
  INVOICE_CANCELLED
  INVOICE_CREDITED
  REFUND_REQUESTED
  REFUND_APPROVED
