//
// COMMERCIAL SUMMARIES
//

model CommercialSummary {
  id              String    @id @default(uuid())
  summaryReference String  @unique
  bookingId       String?   @unique
  quoteId         String?   @unique
  basePrice       Decimal   @db.Decimal(10, 2)
