// CRM MODELS

model Customer {
  id                    String           @id @default(uuid())
  customerNumber        String?          @unique
  firstName             String
  lastName              String
  displayName           String?
  email                 String?
  phone                 String?
  alternativePhone      String?
  dateOfBirth           DateTime?
  nationality           String?
  countryOfResidence    String?
  idNumber              String?
  idType                String?
  gender                String?
  title                 String?
  occupation            String?
  company               String?
  source                String?
  referrerCustomerId    String?
  marketingOptIn        Boolean          @default(false)
  isCorporate           Boolean          @default(false)
  isTravelAgent         Boolean          @default(false)
  isVip                 Boolean          @default(false)
  lifetimeValue         Decimal          @db.Decimal(12, 2) @default(0)
  totalSpend            Decimal          @db.Decimal(12, 2) @default(0)
  totalBookings         Int              @default(0)
  totalTripsCompleted   Int              @default(0)
  totalTripsCancelled   Int              @default(0)
  totalRewardsEarned    Decimal          @db.Decimal(12, 2) @default(0)
  referralCount         Int              @default(0)
  outstandingBalance    Decimal          @db.Decimal(12, 2) @default(0)
  lastBookingAt         DateTime?
  lastVisitAt           DateTime?
  firstVisitAt          DateTime?
  nextAppointmentAt     DateTime?
  preferredLanguage     String?
  preferredCurrency     String?
  notes                 String?          @db.Text
  metadata              Json?
  status                CustomerStatus   @default(ACTIVE)
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  contacts              CustomerContact[]
  addresses             CustomerAddress[]
  preferences           CustomerPreference[]
  segmentAssignments    CustomerSegmentAssignment[]
  tags                  CustomerTag[]
  timeline              CustomerTimeline[]
  interactions          CustomerInteraction[]
  consents              CustomerConsent[]
  outgoingRelationships CustomerRelationship[] @relation("CustomerReferrer")
  incomingRelationships CustomerRelationship[] @relation("CustomerRelated")
  documents             CustomerDocument[]
  loyaltyAccount        LoyaltyAccount?

  @@index([email])
  @@index([phone])
  @@index([customerNumber])
  @@index([status])
  @@index([isVip])
  @@index([isCorporate])
  @@index([lastVisitAt])
  @@index([lifetimeValue])
  @@index([createdAt])
  @@map("customers")
}

model CustomerContact {
  id          String         @id @default(uuid())
  customerId  String
  type        ContactType
  value       String
  label       String?
  isPrimary   Boolean        @default(false)
  isVerified  Boolean        @default(false)
  verifiedAt  DateTime?
  purpose     ContactPurpose @default(PRIMARY)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, type, value])
  @@index([customerId])
  @@index([type])
  @@map("customer_contacts")
}

model CustomerAddress {
  id            String      @id @default(uuid())
  customerId    String
  type          AddressType
  line1          String
  line2          String?
  city           String?
  region         String?
  country        String?
  postalCode     String?
  isPrimary      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([country])
  @@map("customer_addresses")
}

model CustomerPreference {
  id            String   @id @default(uuid())
  customerId    String
  category      String
  key           String
  value         String
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, category, key])
  @@index([customerId])
  @@index([category])
  @@map("customer_preferences")
}

model CustomerSegment {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  color       String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments CustomerSegmentAssignment[]

  @@index([code])
  @@index([isActive])
  @@index([priority])
  @@map("customer_segments")
}

model CustomerSegmentAssignment {
  id          String    @id @default(uuid())
  customerId  String
  segmentId   String
  assignedBy  String?
  expiresAt   DateTime?
  metadata    Json?
  assignedAt  DateTime  @default(now())

  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  segment  CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([customerId, segmentId])
  @@index([customerId])
  @@index([segmentId])
  @@index([expiresAt])
  @@map("customer_segment_assignments")
}

model CustomerTag {
  id          String   @id @default(uuid())
  customerId  String
  tag         String
  color       String?
  metadata    Json?
  createdBy   String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, tag])
  @@index([customerId])
  @@index([tag])
  @@map("customer_tags")
}

model CustomerTimeline {
  id                String          @id @default(uuid())
  customerId        String
  eventType         TimelineEventType
  description       String
  relatedEntityType String?
  relatedEntityId   String?
  metadata          Json?
  recordedBy        String?
  createdAt         DateTime        @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([eventType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([createdAt])
  @@map("customer_timelines")
}

model CustomerInteraction {
  id                String              @id @default(uuid())
  customerId        String
  type              InteractionType
  direction         InteractionDirection @default(INBOUND)
  subject           String?
  summary           String?
  details           String?             @db.Text
