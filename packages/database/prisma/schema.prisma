model FinanceAuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      FinanceAuditAction
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityId])
  @@index([entityType])
  @@index([createdAt])
  @@map("finance_audit_logs")
}
