//
// REFUND POLICIES
//

model RefundCalculation {
  id                String       @id @default(uuid())
  calculationReference String   @unique
  bookingId         String
  baseAmount        Decimal      @db.Decimal(10, 2)
  penaltyAmount     Decimal      @db.Decimal(10, 2) @default(0)
