  calculatedAt       DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([calculationReference])
  @@index([calculatedAt])
  @@map("refund_calculations")
}

//
// TAXES
//

model TaxRule {
  id            String         @id @default(uuid())
  name          String
  description   String?
  type          TaxType
  jurisdiction  TaxJurisdiction
  rate          Decimal        @db.Decimal(5, 4)
