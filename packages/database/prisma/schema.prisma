generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum OtpPurpose {
  LOGIN
  BOOKING_CONFIRMATION
  PAYMENT_CONFIRMATION
  PASSWORD_RESET
}

enum PartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum AuthEvent {
  LOGIN_REQUESTED
  LOGIN_SUCCESS
  LOGIN_FAILED
  OTP_SENT
  OTP_VERIFIED
  SESSION_CREATED
  SESSION_REVOKED
  LOGOUT
}

//
// EXPERIENCES
//

enum ExperienceCategory {
  TRANSPORT
  LEISURE
  ADVENTURE
  PRIVATE
  CORPORATE
}

model Experience {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  description         String?  @db.Text
  shortDescription    String?  @db.Text
  durationMinutes     Int?
  defaultPrice        Decimal? @db.Decimal(10, 2)
  currency            String?  @default("KES")
  category            ExperienceCategory
  isFeatured          Boolean  @default(false)
  isActive            Boolean  @default(true)
  heroImageUrl        String?
  galleryUrls         String[] @default([])
  maxGroupSize        Int?
  minGroupSize        Int?
  requirements        String[] @default([])
  includes            String[] @default([])
  highlights          String[] @default([])
  meta                Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  routes              ExperienceRoute[]
  departures          Departure[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
  @@map("experiences")
}

//
// EXPERIENCE ROUTES (many-to-many)
//

model ExperienceRoute {
  id            String   @id @default(uuid())
  experienceId  String
  routeId       String
  isDefault     Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  experience    Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  route         Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([experienceId, routeId])
  @@index([experienceId])
  @@index([routeId])
  @@map("experience_routes")
}

//
// ROUTES
//

model Route {
  id                      String   @id @default(uuid())
  name                    String
  code                    String   @unique
  description             String?  @db.Text
  estimatedDurationMinutes Int?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  stops                   RouteStop[]
  departures              Departure[]
  experienceRoutes        ExperienceRoute[]

  @@index([isActive])
  @@map("routes")
}

model RouteStop {
  id                        String   @id @default(uuid())
  routeId                   String
  name                      String
  code                      String?  @unique
  sequence                  Int
  latitude                  Decimal? @db.Decimal(10, 8)
  longitude                 Decimal? @db.Decimal(11, 8)
  isPickupPoint             Boolean  @default(true)
  isDropoffPoint            Boolean  @default(true)
  estimatedArrivalMinutes   Int?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  pickupBookings Booking[] @relation("PickupStopBookings")

  @@unique([routeId, sequence])
  @@unique([routeId, code])
  @@index([routeId])
  @@map("route_stops")
}

//
// FLEET
//

enum VesselStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
}

model Vessel {
  id              String        @id @default(uuid())
  name            String        @unique
  registration    String?       @unique
  capacity        Int
  status          VesselStatus  @default(ACTIVE)
  type            VesselType?
  operatorName    String?
  ownerName       String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  departures      Departure[]
  maintenanceLogs VesselMaintenanceLog[]

  @@index([status])
  @@index([name])
  @@map("vessels")
}

enum VesselType {
  FERRY
  SPEEDBOAT
  DHOW
  CATAMARAN
  CATAMARAN_LUXURY
}

model VesselMaintenanceLog {
  id          String   @id @default(uuid())
  vesselId    String
  description String
  performedAt DateTime
  createdAt   DateTime @default(now())

  vessel Vessel @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@index([vesselId])
  @@index([performedAt])
  @@map("vessel_maintenance_logs")
}

//
// DEPARTURES
//

enum DepartureStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  COMPLETED
  CANCELLED
}

model Departure {
  id                    String           @id @default(uuid())
  vesselId              String
  routeId               String
  experienceId          String
  departureDateTime     DateTime
  arrivalDateTime       DateTime?
  totalCapacity         Int
  bookedSeats           Int              @default(0)
  availableCapacity     Int
  status                DepartureStatus  @default(SCHEDULED)
  specialInstructions   String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  vessel     Vessel     @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  route      Route      @relation(fields: [routeId], references: [id], onDelete: Restrict)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Restrict)
  bookings   Booking[]

  @@index([vesselId])
  @@index([routeId])
  @@index([experienceId])
  @@index([departureDateTime])
  @@index([status])
  @@map("departures")
}

//
// GUESTS
//

model Guest {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  idNumber        String?
  nationality     String?
  country         String?
  dateOfBirth     DateTime?
  specialRequests String?
  notes           String?
  marketingOptIn  Boolean  @default(false)
  totalVisits     Int      @default(0)
  firstVisitAt    DateTime?
  lastVisitAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        Booking[]

  @@index([email])
  @@index([phone])
  @@index([lastVisitAt])
  @@map("guests")
}

//
// BOOKINGS
//

enum BookingSource {
  PARTNER
  DIRECT
  ADMIN
  HOTEL
  CORPORATE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingPaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

model Booking {
  id                  String           @id @default(uuid())
  bookingReference    String           @unique
  departureId         String
  partnerId           String
  guestId             String?
  totalGuests         Int
  totalAmount         Decimal          @db.Decimal(10, 2)
  currency            String           @default("KES")
  status              BookingStatus    @default(PENDING)
  paymentStatus       BookingPaymentStatus    @default(PENDING)
  source              BookingSource    @default(PARTNER)
  pickupStopId        String?
  specialRequests     String?
  notes               String?
  cancelledAt         DateTime?
  cancelledBy         String?
  cancellationReason  String?
  rewardEligible      Boolean          @default(true)
  rewardProcessedAt   DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  departure        Departure          @relation(fields: [departureId], references: [id], onDelete: Restrict)
  partner          PartnerProfile     @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  guest            Guest?             @relation(fields: [guestId], references: [id])
  pickupStop       RouteStop?         @relation("PickupStopBookings", fields: [pickupStopId], references: [id])
  guests           BookingGuest[]
  statusHistory    BookingStatusHistory[]
  rewards          RewardTransaction[]

  @@index([departureId])
  @@index([partnerId])
  @@index([guestId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model BookingGuest {
  id          String   @id @default(uuid())
  bookingId   String
  fullName    String
  idNumber    String?
  phoneNumber String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_guests")
}

model BookingStatusHistory {
  id              String   @id @default(uuid())
  bookingId       String
  oldStatus       BookingStatus?
  newStatus       BookingStatus
  reason          String?
  changedByUserId String?
  changedAt       DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user   User?   @relation("BookingAuditUser", fields: [changedByUserId], references: [id])

  @@index([bookingId])
  @@index([changedAt])
  @@map("booking_status_history")
}

//
// REWARDS
//

enum RewardStatus {
  PENDING
  APPROVED
  PAID_OUT
  EXPIRED
  REVERSED
}

model RewardTransaction {
  id              String       @id @default(uuid())
  bookingId       String       @unique
  partnerId       String
  ruleId          String
  version         Int          @default(1)
  pointsEarned    Int
  cashValue       Decimal?     @db.Decimal(10, 2)
  currency        String?      @default("KES")
  status          RewardStatus @default(PENDING)
  description     String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  processedAt     DateTime?

  booking Booking    @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  partner PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  rule    RewardRule   @relation(fields: [ruleId], references: [id])

  @@index([partnerId])
  @@index([ruleId])
  @@index([status])
  @@index([createdAt])
  @@map("reward_transactions")
}

model RewardRule {
  id              String   @id @default(uuid())
  name            String   @unique
  version         Int      @default(1)
  description     String?
  pointsPerBooking Int
  cashMultiplier  Decimal? @db.Decimal(5, 4)
  currency        String?  @default("KES")
  isActive        Boolean  @default(true)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  minGuests       Int?     @default(1)
  maxGuests       Int?
  experienceIds   String[] @default([])
  routeIds        String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    RewardTransaction[]

  @@index([isActive])
  @@index([effectiveFrom, effectiveTo])
  @@map("reward_rules")
}
// USERS
//

model User {
  id String @id @default(uuid())

  email String? @unique
  phone String? @unique

  firstName String
  lastName  String

  status UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  lastLoginAt DateTime?

  roles UserRole[]

  sessions  Session[]
  otpTokens OtpToken[]
  authLogs  AuthLog[]

  partnerProfile       PartnerProfile?
  partnerStatusChanges PartnerStatusHistory[] @relation("PartnerStatusChangedBy")

  bookingStatusChanges BookingStatusHistory[] @relation("BookingAuditUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("users")
}

//
// ROLES
//

model Role {
  id String @id @default(uuid())

  name String @unique

  description String?

  users UserRole[]

  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

//
// PERMISSIONS
//

model Permission {
  id String @id @default(uuid())

  key String @unique

  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissions")
}

//
// USER ROLES
//

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

//
// ROLE PERMISSIONS
//

model RolePermission {
  roleId String

  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

//
// SESSIONS
//

model Session {
  id String @id @default(uuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String @unique

  expiresAt DateTime

  revokedAt DateTime?

  ipAddress String?

  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

//
// OTP TOKENS
//

model OtpToken {
  id String @id @default(uuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  hashedOtp String

  purpose OtpPurpose

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@map("otp_tokens")
}

//
// AUTH LOGS
//

model AuthLog {
  id String @id @default(uuid())

  userId String?

  user User? @relation(fields: [userId], references: [id])

  event AuthEvent

  ipAddress String?

  userAgent String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("auth_logs")
}

//
// PARTNER PROFILE
//

model PartnerProfile {
  id String @id @default(uuid())

  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  partnerCode String @unique

  companyName String?

  commissionRate Decimal @db.Decimal(5, 2)

  status PartnerStatus @default(ACTIVE)

  joinedAt DateTime @default(now())

  payoutAccounts PartnerPayoutAccount[]

  statusHistory PartnerStatusHistory[]

  bookings Booking[]
  rewards RewardTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("partner_profiles")
}

//
// PARTNER PAYOUT ACCOUNTS
//

model PartnerPayoutAccount {
  id String @id @default(uuid())

  partnerId String

  partner PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  accountName String

  accountNumber String

  bankName String?

  mpesaNumber String?

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([partnerId])
  @@map("partner_payout_accounts")
}

//
// PARTNER STATUS HISTORY
//

model PartnerStatusHistory {
  id String @id @default(uuid())

  partnerId String

  partner PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  oldStatus PartnerStatus

  newStatus PartnerStatus

  reason String?

  changedByUserId String?

  changedBy User? @relation("PartnerStatusChangedBy", fields: [changedByUserId], references: [id])

  createdAt DateTime @default(now())

@@index([partnerId])
@@index([changedByUserId])
@@map("partner_status_history")
}

//
// OPERATIONS DOMAIN
//

enum VoyageStatus {
  PLANNED
  READY
  BOARDING
  DEPARTED
  ARRIVED
  COMPLETED
  CANCELLED
  ABORTED
}

enum CrewRole {
  CAPTAIN
  DECKHAND
  GUIDE
  ENGINEER
  OPERATIONS_MANAGER
}

enum ManifestStatus {
  RESERVED
  CHECKED_IN
  BOARDED
  ON_VOYAGE
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum IncidentType {
  MEDICAL
  MECHANICAL
  WEATHER
  PASSENGER
  SAFETY
  NAVIGATION
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReadinessCheckType {
  CREW_ASSIGNED
  MAINTENANCE_COMPLETE
  INSPECTION_COMPLETE
  FUEL_CONFIRMED
  SAFETY_EQUIPMENT_CONFIRMED
  WEATHER_ACCEPTABLE
}

model Voyage {
  id                 String        @id @default(uuid())
  voyageNumber       String        @unique
  departureId        String        @unique
  vesselId           String
  routeId            String
  status             VoyageStatus  @default(PLANNED)
  scheduledDeparture DateTime
  actualDeparture    DateTime?
  scheduledArrival   DateTime?
  actualArrival      DateTime?
  captainId          String?
  operationalNotes   String?       @db.Text
  weatherSummary     String?       @db.Text
  cancellationReason String?
  completionSummary  String?       @db.Text
  version            Int           @default(1)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
  @@index([departureId])
  @@index([vesselId])
  @@index([captainId])
  @@index([scheduledDeparture])
  @@map("voyages")
}

model CrewMember {
  id           String    @id @default(uuid())
  userId       String?   @unique
  firstName    String
  lastName     String
  crewRole     CrewRole
  licenseNumber String?
  certification String?
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([crewRole])
  @@index([isActive])
  @@map("crew_members")
}

model CrewAssignment {
  id        String   @id @default(uuid())
  voyageId  String
  crewMemberId String
  crewRole    CrewRole
  assignedBy  String
  assignedAt  DateTime @default(now())
  notes       String?

  @@unique([voyageId, crewMemberId])
  @@index([voyageId])
  @@index([crewMemberId])
  @@map("crew_assignments")
}

model PassengerManifest {
  id            String        @id @default(uuid())
  voyageId      String
  bookingId     String
  guestId       String
  status        ManifestStatus @default(RESERVED)
  checkInId     String?       @unique
  boardingId    String?       @unique
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  version       Int           @default(1)

  @@unique([voyageId, bookingId])
  @@index([voyageId])
  @@index([bookingId])
  @@index([guestId])
  @@index([status])
  @@map("passenger_manifests")
}

model CheckIn {
  id         String   @id @default(uuid())
  manifestId String   @unique
  voyageId   String
  checkedInAt DateTime @default(now())
  checkedById String
  boardingGroup String?
  notes      String?

  @@index([voyageId])
  @@index([checkedInAt])
  @@map("check_ins")
}

model Boarding {
  id         String   @id @default(uuid())
  manifestId String   @unique
  voyageId   String
  boardedAt   DateTime @default(now())
  boardedById String
  status      String   @default("BOARDED")
  notes       String?

  @@index([voyageId])
  @@index([boardedAt])
  @@map("boardings")
}

model VesselReadinessCheck {
  id         String              @id @default(uuid())
  voyageId   String
  checkType  ReadinessCheckType
  status     Boolean             @default(false)
  verifiedBy String?
  verifiedAt DateTime?
  notes      String?

  @@unique([voyageId, checkType])
  @@index([voyageId])
  @@map("vessel_readiness_checks")
}

model OperationalIncident {
  id          String        @id @default(uuid())
  voyageId    String
  type        IncidentType
  severity    IncidentSeverity @default(MEDIUM)
  description String
  resolution  String?
  recordedBy  String
  recordedAt  DateTime      @default(now())
  metadata    Json?

  @@index([voyageId])
  @@index([type])
  @@index([severity])
  @@map("operational_incidents")
}

model VoyageTimeline {
  id        String   @id @default(uuid())
  voyageId  String
  eventType String
  eventAt   DateTime @default(now())
  userId    String?
  notes     String?
  metadata  Json?

  @@index([voyageId])
  @@index([eventType])
  @@index([eventAt])
  @@map("voyage_timelines")
}

//
// COMMERCIAL DOMAIN
//

enum PricingStrategy {
  FIXED
  SEASONAL
  DYNAMIC
  PARTNER
  CORPORATE
  HOTEL
  RESIDENT
  INTERNATIONAL
  PRIVATE_CHARTER
  VIP
}

enum PriceStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
  FREE_ITEM
  BUNDLE
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  DEPLETED
}

enum PromotionStackability {
  STACKABLE
  NON_STACKABLE
}

enum QuoteStatus {
  DRAFT
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELLED
}

enum HoldStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  RELEASED
}

enum CancellationWindow {
  FLEXIBLE
  MODERATE
  STRICT
  SUPER_STRICT
  CUSTOM
}

enum RefundCalculationStatus {
  PENDING
  CALCULATED
  APPROVED
  EXECUTED
  FAILED
}

enum CommissionType {
  PARTNER
  CORPORATE
  TRAVEL_AGENT
  REFERRAL
  INTERNAL_SALES
}

enum TaxType {
  VAT
  TOURISM_LEVY
  MARINE_CONSERVATION_FEE
  SERVICE_CHARGE
  COUNTY_TAX
}

enum TaxJurisdiction {
  KENYA
  INTERNATIONAL
  CUSTOM
}

enum AddOnCategory {
  TRANSPORT
  CATERING
  EXPERIENCE
  SERVICE
  INSURANCE
  MERCHANDISE
}

enum RuleType {
  SEASON
  HOLIDAY
  WEEKEND
  TIME_OF_DAY
  GROUP_SIZE
  CUSTOMER_CATEGORY
  CUSTOMER_TYPE
  EXPERIENCE
  ROUTE
  DEPARTURE_TIME
  VESSEL_CLASS
  PROMOTIONAL_PERIOD
  MIN_STAY
  ADVANCE_BOOKING
  CUSTOM
}

//
// PRICE LISTS
//

model PriceList {
  id              String        @id @default(uuid())
  name            String
  description     String?
  experienceId    String?
  status          PriceStatus   @default(DRAFT)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  priority        Int           @default(0)
  version         Int           @default(1)
  currency        String        @default("KES")
  createdBy       String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           PriceListItem[]
  rules           PricingRule[]
  addOnPrices     AddOnPrice[]

  @@index([experienceId])
  @@index([status])
  @@index([effectiveFrom, effectiveTo])
  @@index([priority])
  @@map("price_lists")
}

model PriceListItem {
  id            String    @id @default(uuid())
  priceListId   String
  name          String
  description   String?
  basePrice     Decimal   @db.Decimal(10, 2)
  currency      String    @default("KES")
  customerCategory String?
  ageGroup      String?
  minGuests     Int?
  maxGuests     Int?
  seatClass     String?
  meta          Json?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  priceList     PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([priceListId, name, customerCategory, ageGroup, seatClass])
  @@index([priceListId])
  @@index([customerCategory])
  @@map("price_list_items")
}

//
// PRICING RULES
//

model PricingRule {
  id           String   @id @default(uuid())
  priceListId  String?
  name         String
  description  String?
  ruleType     RuleType
  conditions   Json
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  effectiveFrom DateTime
  effectiveTo  DateTime?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  priceList    PriceList? @relation(fields: [priceListId], references: [id], onDelete: Cascade)

