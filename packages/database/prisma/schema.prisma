  effectiveTo     DateTime?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([experienceId])
  @@index([partnerId])
  @@index([windowType])
  @@index([effectiveFrom, effectiveTo])
